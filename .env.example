# Optional: Set an API token to require authentication for /api/* routes
# API_TOKEN=your-secret-token-here

# Optional: Comma-separated CORS origins (default: same-origin only)
# CORS_ORIGINS=https://your-app.railway.app

# Optional: Port (default: 8000)
# PORT=8000

# Optional: Slack webhook URL for visit and pipeline run notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
